!/nextjs/.yarn/patches
!/nextjs/.yarn/plugins
!/nextjs/.yarn/releases
!/nextjs/.yarn/versions

# testing
/nextjs/coverage

# next.js
/nextjs/.next/
/nextjs/out/

# production
/nextjs/build

# misc
/nextjs/.DS_Store
/nextjs/*.pem

# debug
/nextjs/npm-debug.log*
/nextjs/yarn-debug.log*
/nextjs/yarn-error.log*
